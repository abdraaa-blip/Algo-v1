{
  "name": "algo2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --max-warnings=400",
    "lint:strict": "eslint --max-warnings=0",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run --coverage",
    "test:watch": "vitest watch",
    "clear-cache": "node scripts/clear-cache.js",
    "clean:dry": "node scripts/clear-cache.js --dry-run",
    "dev:fresh": "node scripts/clear-cache.js && next dev",
    "autopilot": "npx tsx scripts/algo-autopilot.ts",
    "autopilot:quick": "npx tsx scripts/algo-autopilot.ts --quick",
    "autopilot:setup": "npx tsx scripts/algo-autopilot.ts --setup",
    "autopilot:analyze": "npx tsx scripts/algo-pattern-analyzer.ts",
    "autopilot:heal": "npx tsx scripts/algo-link-healer.ts",
    "autopilot:repair": "npx tsx scripts/algo-repair-engine.ts",
    "i18n:check": "node scripts/check-i18n-locales.mjs",
    "perf:budget": "node scripts/check-performance-budget.mjs",
    "report:daily": "node scripts/generate-daily-report.mjs",
    "verify:perf": "npm run build && npm run perf:budget",
    "db:apply-ecosystem": "node scripts/apply-algo-ecosystem-sql.mjs",
    "ecosystem:check": "node scripts/verify-ecosystem.mjs",
    "ecosystem:check:strict": "node scripts/verify-ecosystem.mjs --strict",
    "verify:api-guards": "node scripts/verify-api-route-guards.mjs",
    "verify:release": "npm run ecosystem:check && npm run i18n:check && npm run verify:api-guards && npm run typecheck && npm run lint:strict && npm run test:run && npm run build",
    "verify:full": "npm run verify:release && npm run perf:budget && npm run report:daily",
    "clean": "node scripts/clear-cache.js"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.4",
    "ai": "^6.0.146",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "glob": "^13.0.6",
    "html2canvas": "^1.4.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "next-intl": "^4.9.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "stripe": "^22.0.1",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "pg": "^8.20.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.1.4"
  }
}
