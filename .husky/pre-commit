#!/bin/sh
# ═══════════════════════════════════════════════════════════════════════════════
# ALGO AUTOPILOT PRE-COMMIT HOOK
# Prevents broken code from being committed
# ═══════════════════════════════════════════════════════════════════════════════

echo ""
echo "╔════════════════════════════════════════════════════════════╗"
echo "║           ALGO AUTOPILOT - Pre-Commit Check                ║"
echo "╚════════════════════════════════════════════════════════════╝"
echo ""

# Get staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' || true)

if [ -z "$STAGED_FILES" ]; then
  echo "No TypeScript files staged. Skipping checks."
  exit 0
fi

echo "Checking staged files..."
echo "$STAGED_FILES" | head -5
TOTAL=$(echo "$STAGED_FILES" | wc -l)
if [ "$TOTAL" -gt 5 ]; then
  echo "... and $((TOTAL - 5)) more files"
fi
echo ""

# Run TypeScript check on staged files
echo "[1/3] TypeScript check..."
npx tsc --noEmit 2>&1 | head -20
TS_EXIT=$?

if [ $TS_EXIT -ne 0 ]; then
  echo ""
  echo "╔════════════════════════════════════════════════════════════╗"
  echo "║  COMMIT BLOCKED: TypeScript errors detected                ║"
  echo "║  Fix errors before committing.                             ║"
  echo "╚════════════════════════════════════════════════════════════╝"
  exit 1
fi
echo "TypeScript: OK"

# Run ESLint on staged files
echo ""
echo "[2/3] ESLint check..."
echo "$STAGED_FILES" | xargs npx eslint --quiet 2>&1 | head -20
ESLINT_EXIT=$?

if [ $ESLINT_EXIT -ne 0 ]; then
  echo ""
  echo "╔════════════════════════════════════════════════════════════╗"
  echo "║  COMMIT BLOCKED: ESLint errors detected                    ║"
  echo "║  Run 'npx eslint --fix' to auto-fix issues.                ║"
  echo "╚════════════════════════════════════════════════════════════╝"
  exit 1
fi
echo "ESLint: OK"

# Run quick autopilot check
echo ""
echo "[3/3] Autopilot quick check..."
npm run autopilot:quick 2>&1 | tail -10
AUTOPILOT_EXIT=$?

if [ $AUTOPILOT_EXIT -ne 0 ]; then
  echo ""
  echo "╔════════════════════════════════════════════════════════════╗"
  echo "║  COMMIT BLOCKED: Autopilot found issues                    ║"
  echo "║  Check reports/ for details.                               ║"
  echo "╚════════════════════════════════════════════════════════════╝"
  exit 1
fi

echo ""
echo "╔════════════════════════════════════════════════════════════╗"
echo "║  ALL CHECKS PASSED - Commit allowed                        ║"
echo "╚════════════════════════════════════════════════════════════╝"
echo ""

exit 0
