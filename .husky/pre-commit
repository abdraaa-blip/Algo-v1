#!/bin/sh
# ALGO · pre-commit — TS + ESLint + autopilot rapide (fichiers stagés .ts/.tsx uniquement)

echo ""
echo "ALGO pre-commit · vérifications"
echo ""

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' || true)

if [ -z "$STAGED_FILES" ]; then
  echo "Aucun fichier .ts/.tsx stagé — skip checks."
  exit 0
fi

echo "$STAGED_FILES" | head -5
TOTAL=$(echo "$STAGED_FILES" | wc -l | tr -d ' ')
if [ "$TOTAL" -gt 5 ]; then
  echo "... et $((TOTAL - 5)) fichier(s) de plus"
fi
echo ""

echo "[1/3] TypeScript…"
if ! npx tsc --noEmit; then
  echo "COMMIT BLOQUÉ : erreurs TypeScript."
  exit 1
fi

echo "[2/3] ESLint…"
# Windows : une seule ligne « npx eslint f1 f2 … » avec des centaines de chemins
# dépasse la limite de longueur (8191). Découper en lots avec xargs -n.
if ! echo "$STAGED_FILES" | tr -d '\r' | grep -v '^$' | xargs -n 25 npx eslint --max-warnings=0; then
  echo "COMMIT BLOQUÉ : ESLint."
  exit 1
fi

echo "[3/3] Autopilot quick…"
# Même logique qu’en CI : ne bloque pas sur les centaines de signalements style/i18n du dépôt.
export AUTOPILOT_PRE_COMMIT=1
if ! npm run autopilot:quick; then
  echo "COMMIT BLOQUÉ : autopilot:quick."
  exit 1
fi

echo ""
echo "Pre-commit OK."
exit 0
