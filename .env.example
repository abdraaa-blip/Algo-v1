# =============================================================================
# ALGO Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================================

# ─── Vercel (Production / Preview) ───────────────────────────────────────────
# Les variables sensibles ne viennent pas de Git : Vercel → Project → Settings → Environment Variables.
# .env.local n’est jamais poussé sur Vercel : recopie les clés ou utilise `vercel env pull` en local.
# Copie NEXT_PUBLIC_SUPABASE_URL et la clé publique depuis Supabase → Settings → API (même projet).
# NEXT_PUBLIC_* est exposé au navigateur : JWT anon ou sb_publishable_ uniquement, jamais sb_secret_ / service role.
# Après changement d’une variable sur Vercel : Redeploy pour recharger le runtime Edge/Serverless.
# Laisse les « System Environment Variables » activées (VERCEL_URL, VERCEL_ENV, etc. sont utilisées).
# CRON_SECRET : requis en prod pour sécuriser les routes /api/cron/*.

# Dashboard observabilité (`/observability` + GET/POST `/api/observability/logs`) en production / preview.
# Sans cette variable : accès uniquement en `NODE_ENV=development`.
# ALGO_OBSERVABILITY_DASHBOARD=1

# ─── Supabase (Required for auth and database) ───────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Clé publique : JWT anon (eyJ…) OU clé plateforme sb_publishable_… (voir Settings → API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-jwt-here
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Service role — UNIQUEMENT serveur, jamais NEXT_PUBLIC. JWT (eyJ…) OU sb_secret_…
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt-here
# SUPABASE_SECRET_KEY=sb_secret_...

# URI Postgres directe (Settings → Database) — pour npm run db:apply-ecosystem uniquement, pas pour le navigateur.
# DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxxx.supabase.co:5432/postgres
# (alternative) SUPABASE_DB_URL=...

# Persistance automatique des lots tendances (optionnel) lors de GET /api/v1/trends
# ALGO_SNAPSHOT_PERSIST=1

# Régions pour le cron /api/cron/snapshot-trends (défaut ALL,FR,US). ALL = agrégat multi-pays.
# ALGO_SNAPSHOT_CRON_REGIONS=ALL,FR,US

# Régions pour le cron /api/cron/radar-snapshot (historique7j). Défaut : FR,US — étendre ex. GB,NG,MA,SN si besoin
# ALGO_RADAR_CRON_REGIONS=FR,US,GB

# Secret pour tous les /api/cron/* (dont snapshot-trends). Requis sur Vercel pour les crons.
# CRON_SECRET=long-random-secret

# ─── Site URL (SEO: canonical, sitemap, Open Graph) ─────────────────────────
# Production: https://ton-domaine.com (sans slash final)
# NEXT_PUBLIC_BASE_URL=https://algo.app

# ─── Mentions légales & contact (pages /legal et bas de politique de confidentialité) ─
# NEXT_PUBLIC_SITE_OPERATOR_NAME=Ma Société SAS
# NEXT_PUBLIC_SITE_OPERATOR_ADDRESS=123 rue Exemple, 75001 Paris, France
# NEXT_PUBLIC_CONTACT_EMAIL=contact@votredomaine.com
# NEXT_PUBLIC_SITE_HOSTING=Vercel Inc. — https://vercel.com

# ─── Optional: Analytics (RGPD: activer seulement si consentement dans l’UI) ─
# Plausible — domaine configuré sur plausible.io (ex. algo.app)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=algo.app
# NEXT_PUBLIC_ANALYTICS_ID=your-analytics-id

# ─── Live Data APIs (Required for real-time content) ─────────────────────────
# Sans clés valides : les routes renvoient souvent fallback ou listes vides, mais le chargement global
# de la home continue (YouTube / viral-content / tendances ne doivent pas être bloqués par une news vide).
# NewsAPI - Get your key at https://newsapi.org/
# Utilisé par `/api/live-news`, `/api/news`, `real-data-service` — une seule des deux suffit :
NEWSAPI_KEY=your-newsapi-key-here
# Variante acceptée (même usage) :
# NEWS_API_KEY=

# YouTube Data API v3 - Get your key at https://console.cloud.google.com/
# Utilisé par /api/videos, /api/social/youtube/video-metrics et le bloc YouTube optionnel du Viral Control (?videoUrl=).
YOUTUBE_API_KEY=your-youtube-api-key-here

# TMDB (The Movie Database) - Get your key at https://themoviedb.org/settings/api
TMDB_API_KEY=your-tmdb-api-key-here

# Last.fm - Get your key at https://last.fm/api/account/create
LASTFM_API_KEY=your-lastfm-api-key-here

# Spotify Web API (optionnel) — GET `/api/spotify` (charts / ingest cron). La page `/music` utilise Last.fm → `/api/live-music`.
# Dashboard : https://developer.spotify.com/dashboard — Client credentials flow.
# SPOTIFY_CLIENT_ID=your-spotify-client-id
# SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# ─── Optional: External APIs ─────────────────────────────────────────────────
# REDDIT_CLIENT_ID=your-reddit-client-id
# REDDIT_CLIENT_SECRET=your-reddit-client-secret
# GITHUB_TOKEN=your-github-personal-access-token

# ─── Optional: Stripe (abonnement PRO) ────────────────────────────────────────
# Dashboard Stripe → clé secrète (mode test ou live). Ne jamais exposer au client.
# STRIPE_SECRET_KEY=sk_test_...
# Prix récurrent « Pro » (Price ID) créé dans Stripe Product catalog.
# STRIPE_PRICE_PRO_MONTHLY=price_...
# Webhook : URL publique https://<ton-domaine>/api/billing/webhook · événements checkout.session.completed, customer.subscription.*
# STRIPE_WEBHOOK_SECRET=whsec_...
# SUPABASE_SERVICE_ROLE_KEY requis pour que le webhook mette à jour `profiles` (voir migration profiles_billing).
# STRIPE_PUBLISHABLE_KEY=pk_test_...  (optionnel : Elements / Payment Sheet plus tard)
#
# Gate optionnelle : fusion dashboard sans recherche YouTube pour les non‑Pro (économise quota API).
# ALGO_FUSION_YOUTUBE_REQUIRE_PRO=1
#
# ─── Checklist côté opérateur (quand tu actives la monétisation) ───────────────
# 1) Appliquer la migration `supabase/migrations/20260411120000_profiles_billing.sql`
# 2) Renseigner STRIPE_SECRET_KEY, STRIPE_PRICE_PRO_MONTHLY, STRIPE_WEBHOOK_SECRET
# 3) SUPABASE_SERVICE_ROLE_KEY sur l’environnement qui reçoit POST /api/billing/webhook
# 4) Créer le webhook Stripe → https://<domaine>/api/billing/webhook (événements subscription + checkout.session.completed)
# 5) (Optionnel) ALGO_FUSION_YOUTUBE_REQUIRE_PRO=1 pour réserver la partie YouTube de /api/intelligence/viral-fusion aux Pro

# ─── Optional: AI Features ───────────────────────────────────────────────────
# OPENAI_API_KEY=your-openai-api-key
# AI_GATEWAY_API_KEY=your-vercel-ai-gateway-key

# ─── Optional: Push Notifications ────────────────────────────────────────────
# VAPID_PUBLIC_KEY=your-vapid-public-key
# VAPID_PRIVATE_KEY=your-vapid-private-key

# ─── Node Environment ────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Intelligence Ops Security (Required for /intelligence/logs access) ─────
# Shared operator token used by:
# - GET/DELETE /api/intelligence/decision-log
# - /intelligence/logs dashboard
INTELLIGENCE_DASHBOARD_TOKEN=replace-with-strong-random-token

# ─── Ecosystem / external apps (optional) ────────────────────────────────────
# Clé(s) pour /api/v1/trends et /api/v1/ingest/events — jamais dans le client public.
# ALGO_PLATFORM_API_KEY=long-random-secret
# ALGO_PLATFORM_API_KEYS=client_a_key,client_b_key
